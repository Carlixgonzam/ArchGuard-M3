digraph ArchGuard {
  rankdir=LR;
  node [shape=ellipse, style=filled, fillcolor=lightblue, fontname=Helvetica];
  edge [fontname=Helvetica, fontsize=10];

  "gateway" [label="gateway"];
  "inventory" [label="inventory"];
  "ledger" [label="ledger"];
  "orders" [label="orders"];
  "payments" [label="payments"];
  "warehouse" [label="warehouse"];

  "warehouse" -> "orders" [color=green, penwidth=2.0, label="permitted"];
  "payments" -> "ledger" [color=green, penwidth=2.0, label="permitted"];
  "inventory" -> "warehouse" [color=green, penwidth=2.0, label="permitted"];
  "gateway" -> "orders" [color=green, penwidth=2.0, label="permitted"];
  "gateway" -> "payments" [color=red, penwidth=2.0, label="violation"];
  "orders" -> "payments" [color=green, penwidth=2.0, label="permitted"];
  "orders" -> "inventory" [color=green, penwidth=2.0, label="permitted"];

  subgraph cluster_legend {
    label="Legend";
    style=dashed;
    fontname=Helvetica;
    leg_g [label="Permitted", shape=box, fillcolor=green, style=filled];
    leg_r [label="Forbidden/Unpermitted", shape=box, fillcolor=red, style=filled, fontcolor=white];
    leg_d [label="Missing (dependsOn)", shape=box, fillcolor=grey, style="filled,dashed"];
  }
}
